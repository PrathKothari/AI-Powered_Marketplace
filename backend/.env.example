# Core Settings
PROJECT_NAME="AI Artisan Marketplace"
API_V1_STR="/api/v1"
SECRET_KEY="CHANGE_THIS_TO_A_SECURE_SECRET_KEY"
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEBUG=True

# Database
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/artisan_marketplace"

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# AI/ML Configuration
ML_MODEL_PATH="./app/ml/models"
DEFAULT_MODEL_VERSION="v1"
STORY_SECONDS_PER_IMAGE=4
STORY_VIDEO_FPS=30
STORY_DEFAULT_MUSIC="assets/music.mp3"
STORY_FONT_PATH=""
STORYBOARD_OUTPUT_DIR="generated-videos"
STORYBOARD_TEMP_DIR="tmp/video-scenes"
STORYBOARD_VIDEO_WIDTH=1080
STORYBOARD_VIDEO_HEIGHT=1920
STORYBOARD_DEFAULT_DURATION_SECONDS=30
STORYBOARD_ASPECT_RATIO="9:16"
STORYBOARD_BACKGROUND_MUSIC_PATH=""
STORYBOARD_BACKGROUND_MUSIC_VOLUME=0.12
STORYBOARD_KEEP_TEMP=False
GEMINI_MODEL_NAME="gemini-1.5-flash"
GEMINI_API_KEY=""
OPENAI_API_KEY=""
OPENAI_MODEL_NAME="gpt-4o-mini"
GOOGLE_CLOUD_LOCATION="us-central1"
GOOGLE_CLOUD_PROJECT=""
GCS_BUCKET_NAME=""
GCS_PUBLIC_PREFIX="videos"


# Copy this to .env and fill in real values. Do NOT commit .env.

# Core
PROJECT_NAME="AI Artisan Marketplace"
API_V1_STR="/api/v1"
SECRET_KEY="change-me-to-a-long-random-string"
ACCESS_TOKEN_EXPIRE_MINUTES=60
DEBUG=False
APP_ENV="production"

# CORS — comma-separated, include your Vercel URL and any custom domain
BACKEND_CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Storage paths (inside the container)
STORY_UPLOAD_DIR=temp_uploads
STORY_OUTPUT_DIR=temp_outputs
STORY_MEDIA_DIR=generated_media

# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=ai-market-asst-1
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL_NAME=gemini-2.5-flash

# On Cloud Run, do NOT set GOOGLE_APPLICATION_CREDENTIALS — workload identity handles auth.
# Locally, point this at your service account JSON:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service_account.json

# Veo
VEO_ENABLED=true
VEO_MODEL_ID=veo-2.0-generate-001

# Firebase / GCS
FIREBASE_PROJECT_ID=ai-market-asst-1
FIREBASE_STORAGE_BUCKET=ai-market-asst-1.firebasestorage.app
GCS_BUCKET_NAME=ai-market-asst-1.firebasestorage.app
GCS_PUBLIC_PREFIX=reels

# These two are only needed if you can't use ADC. Prefer ADC on Cloud Run.
# FIREBASE_PRIVATE_KEY=
# FIREBASE_CLIENT_EMAIL=

# API keys (move to Secret Manager in production)
GEMINI_API_KEY=
FIREBASE_API_KEY=
PINECONE_API_KEY=
PINECONE_IMAGE_INDEX=product-images
PINECONE_TEXT_INDEX=product-text
HF_TOKEN=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=

# Email
EMAIL_SENDER=
EMAIL_PASSWORD=

# Telegram
TELEGRAM_BOT_TOKEN=
FRONTEND_URL=https://your-app.vercel.app

# Core Settings
PROJECT_NAME="AI Artisan Marketplace"
API_V1_STR="/api/v1"
SECRET_KEY="CHANGE_THIS_TO_A_SECURE_SECRET_KEY"
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEBUG=True

# Database
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/artisan_marketplace"

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# AI/ML Configuration
ML_MODEL_PATH="./app/ml/models"
DEFAULT_MODEL_VERSION="v1"

